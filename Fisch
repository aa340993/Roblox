task.spawn(function()
    local char = player.Character
    if not char then isBusy = false trackedZones[child] = nil return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then isBusy = false trackedZones[child] = nil return end

    -- 1. 記錄出發 CFrame（含朝向）與當前手持工具
    originCFrame = hrp.CFrame
    originTool   = char:FindFirstChildOfClass("Tool")

    -- 2. 收起工具（不破壞，放回背包）
