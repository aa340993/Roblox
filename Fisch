    LD.TextColor3 = T.yellow
    LBN.Text     = "📍  " .. iName

    if cfg.whOnBossSpawn then
        sendWebhook("⚔ Boss 出現！", "位置：" .. iName, 16711680)
        LWH.Text = "📨 Webhook 已發送（Boss 出現）"
    end

    -- 4. 取 Boss 位置並飛過去
    local bp = hrp.Position
    if child:IsA("BasePart") then
        bp = child.Position
    else
        local p2 = child:FindFirstChildOfClass("BasePart")
        if p2 then bp = p2.Position end
    end
    LFL.Text = "✈  正在飛過去…"
    flyTo(CFrame.new(bp + Vector3.new(0,5,0)) * (originCFrame - originCFrame.Position))
    LFL.Text = "✈  已抵達"

    -- 5. 到達後立即拿回原本武器（在 Boss 旁邊保持持有）
    if originTool then
        local f = player.Backpack:FindFirstChild(originTool.Name)
        if f then
            f.Parent = char
            LDN.Text = "🗡  持有中：" .. originTool.Name
        end
    end

    -- 6. 等待 Boss 消失
    LWT.Text = "⏳  等待 Boss 消失…"
    while child and child.Parent ~= nil do task.wait(0.3) end
    LWT.Text = "✅  Boss 已消失"

    -- 7. Boss 死後：放下武器再飛回
    local held = char:FindFirstChildOfClass("Tool")
