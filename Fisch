local function getRarity(r)
if not r then return “未知”, Color3.fromRGB(160,160,160) end
local d = rarityMap[r:lower()]
return d and d.zh or r, d and d.color or Color3.fromRGB(160,160,160)
end
local function isRare(zh)
for _, v in ipairs(rareList) do if zh == v then return true end end
return false
end

