        held.Parent = player.Backpack
    end

    if cfg.whOnBossDead then
        sendWebhook("✅ Boss 消失", "位置：" .. iName, 65280)
        LWH.Text = "📨 Webhook 已發送（Boss 消失）"
    end

    -- 8. 統計
    stats.bossCount = stats.bossCount + 1

    -- 9. 飛回原點（保留原始朝向）
    LRT.Text = "🔄  傳回原位…"
    flyTo(originCFrame)
    LRT.Text = "🔄  已回到原本位置"

    task.wait(0.3)

    -- 10. 飛回後拿回原始武器
