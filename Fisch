        if f then
            f.Parent = char
            LDN.Text = "✅  已拿回：" .. originTool.Name
        end
    end

    task.wait(4)
    resetBoss()
    trackedZones[child] = nil
    originCFrame = nil
    originTool   = nil
    isBusy = false
end)
